{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,

    "jsx": "react-jsx",

    "rootDir": "src",
    "outDir": "dist",

    "types": ["node"],

    "esModuleInterop": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true
  },

  "include": [
    "src"
  ]
}