# 2. `apps/cli/.gitignore`

```gitignore
# ============================================
# Dependencies
# ============================================

node_modules/

# ============================================
# Build Output
# ============================================

dist/
build/

# ============================================
# Logs
# ============================================

*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# Coverage
# ============================================

coverage/

# ============================================
# TypeScript
# ============================================

*.tsbuildinfo

# ============================================
# Environment
# ============================================

.env
.env.*
!.env.example

# ============================================
# IDE
# ============================================

.vscode/
.idea/

# ============================================
# OS
# ============================================

.DS_Store
Thumbs.db
desktop.ini